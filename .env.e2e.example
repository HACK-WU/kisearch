# e2e 环境变量模板 —— 复制为 .env.e2e 并填入真实值（.env.e2e 不入库）
#   cp .env.e2e.example .env.e2e

# SiliconFlow 兼容 embedding 服务的 API Key（必填，缺失则整套 e2e 跳过）
SILICONFLOW_API_KEY=
# 可选：覆盖默认端点/模型/维度（缺省用 config 默认：https://api.siliconflow.cn/v1 · Qwen/Qwen3-Embedding-8B · 4096）
GITNEXUS_EMBEDDING_URL=
GITNEXUS_EMBEDDING_MODEL=
GITNEXUS_EMBEDDING_API_KEY=
GITNEXUS_EMBEDDING_DIMS=
