{
  "name": "KiSearch",
  "version": "0.2.0-beta",
  "description": "AI 知识索引整理工具 - 对外部知识进行结构化索引和导航",
  "type": "module",
  "bin": {
    "ki": "./bin/ki.mjs",
    "knowledge-indexer": "./bin/knowledge-indexer.mjs"
  },
  "scripts": {
    "scan-kb": "npx jiti src/scan-kb.ts",
    "manage-index": "npx jiti src/manage-index.ts",
    "query-group": "npx jiti src/query-group.ts",
    "get-module-info": "npx jiti src/get-module-info.ts",
    "sync-relation": "npx jiti src/sync-relation.ts",
    "test": "npx jiti test/manage-index.test.ts",
    "test:all": "npx jiti test/*.test.ts",
    "test:manage-index": "npx jiti test/manage-index.test.ts",
    "test:query-group": "npx jiti test/query-group.test.ts",
    "test:get-module-info": "npx jiti test/get-module-info.test.ts",
    "test:sync-relation": "npx jiti test/sync-relation.test.ts",
    "test:import-kb": "npx jiti test/import-kb.test.ts",
    "test:scan-kb": "npx jiti test/scan-kb.test.ts",
    "test:lib": "npx jiti test/lib.test.ts",
    "test:integration": "npx jiti test/integration.test.ts",
    "test:error-handling": "npx jiti test/error-handling.test.ts",
    "test:scope-isolation": "npx jiti test/scope-isolation.test.ts",
    "test:migrate-keywords": "npx jiti test/migrate-keywords.test.ts",
    "test:config-doctor": "npx jiti test/config-doctor.test.ts",
    "test:scope-doc": "npx jiti test/scope-doc.test.ts",
    "test:zvec-engine": "node --test test/zvec-engine*.test.mjs",
    "test:e2e:kisearch": "node --test test/e2e/kisearch-cli.e2e.network.mjs",
    "test:e2e:step-c": "node --test test/e2e/step-c-cli.e2e.network.mjs",
    "test:e2e:scan-kb": "node --test test/e2e/scan-kb-cli.e2e.network.mjs",
    "build:zvec-engine": "tsc -p tsconfig.src.json",
    "setup": "npx jiti src/setup.ts"
  },
  "keywords": [
    "knowledge",
    "indexer",
    "ai-agent",
    "knowledge-management"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@zvec/zvec": "^0.6.0",
    "commander": "^14.0.0",
    "jiti": "^2.6.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "files": [
    "bin/**/*",
    "scripts/**/*",
    "src/**/*",
    "_template/**/*",
    "dist/zvec-engine/**/*",
    "src/zvec-engine/**/*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
